NODE_ENV=development
PORT=7319
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feishu_expense_audit

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=replace_me
FEISHU_VERIFICATION_TOKEN=replace_me
FEISHU_ENCRYPT_KEY=
FEISHU_API_BASE_URL=https://open.feishu.cn
FEISHU_FILE_DOWNLOAD_ALLOWED_HOSTS=open.feishu.cn,*.feishu.cn,*.feishuapp.cn,*.feishucdn.com,*.larksuite.com,*.larksuitecdn.com
FEISHU_FILE_DOWNLOAD_MAX_BYTES=20971520

FEISHU_NOTIFY_RECEIVE_ID_TYPE=chat_id
FEISHU_NOTIFY_RECEIVE_ID=oc_xxx
FEISHU_APPROVAL_DETAIL_URL_TEMPLATE=https://applink.feishu.cn/client/mini_program/open?mode=appCenter&appId=cli_9cb844403dbb9108&path=pc%2Fpages%2Fin-process%2Findex%3FinstanceId%3D{instanceCode}
APPLICANT_NAME_MAP=

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_VISION_MODEL=gpt-4o-mini

AI_VISION_API_KEY=
AI_VISION_BASE_URL=https://api.openai.com
AI_VISION_MODEL=gpt-4o-mini
AI_VISION_API_STYLE=responses
# GLM example:
# AI_VISION_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_VISION_MODEL=GLM-OCR
# AI_VISION_API_STYLE=chat_completions

APPROVAL_AMOUNT_FIELD_NAMES=费用明细汇总,报销金额,金额,实付金额
APPROVAL_ATTACHMENT_FIELD_NAMES=付款凭证,支付截图,报销凭证,附件,图片/视频,图片
APPROVAL_INVOICE_FIELD_NAMES=发票,发票附件,电子发票,发票图片
APPROVAL_APPLICANT_FIELD_NAMES=申请人,报销人
APPROVAL_HANDLER_FIELD_NAMES=办理人,经办人,付款办理人

LOCAL_STORAGE_DIR=./data/evidences
SAVE_ORIGINAL_FILE=true
SAVE_OCR_RAW_TEXT=false
PERCEPTUAL_HASH_DISTANCE_THRESHOLD=8
AUDIT_WORKER_POLL_MS=1000
AUDIT_JOB_LEASE_SECONDS=300
AUDIT_JOB_MAX_RETRIES=5
OCR_PROVIDER=mock
